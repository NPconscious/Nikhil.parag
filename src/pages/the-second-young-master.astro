---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="The Second Young Master | Nikhil Parag"
  description="Chapter list for The Second Young Master."
>
  <main id="main" class="chapters-page">
    <section class="chapters-content">
      <a href="/personal/" class="back-link">Back to Personal</a>

      <span class="section-label">STORY</span>
      <h1>The Second Young Master</h1>

      <div class="chapter-list" aria-label="Chapters">
        <a href="/the-second-young-master/chapter-1/" class="chapter-card">
          <span>Chapter 1</span>
          <strong>The Second Young Master</strong>
          <p>The academy, the examination, and the first step into the Kasper family profession.</p>
        </a>

        <a href="/the-second-young-master/chapter-2/" class="chapter-card">
          <span>Chapter 2</span>
          <strong>The Engagement</strong>
          <p>A royal celebration, political pressure, and a crisis pulling the great houses into motion.</p>
        </a>

        <a href="/the-second-young-master/chapter-3/" class="chapter-card">
          <span>Chapter 3</span>
          <strong>The Third Year</strong>
          <p>House Solaris teaches politics, administration, and the language of crowds in the third year.</p>
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .chapters-page {
    min-height: 100vh;
    padding: 120px 0 100px;
  }

  .chapters-content {
    width: min(var(--content-width), calc(100% - 48px));
    margin-inline: auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 32px;
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 600;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--text);
    transform: translateX(-2px);
  }

  .chapters-content h1 {
    margin: 0 0 36px;
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.03;
  }

  .chapter-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 22px;
  }

  .chapter-card {
    display: block;
    padding: 32px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
  }

  .chapter-card:hover,
  .chapter-card:focus-visible {
    transform: translateY(-6px);
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.22);
  }

  .chapter-card span {
    display: block;
    margin-bottom: 10px;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .chapter-card strong {
    display: block;
    color: var(--text);
    font-size: 1.35rem;
    line-height: 1.25;
    margin-bottom: 12px;
  }

  .chapter-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .chapter-list {
      gap: 18px;
    }

    .chapter-card {
      padding: 26px;
    }
  }
</style>