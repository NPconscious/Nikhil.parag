---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nikhil Parag" description="Founder of NPconscious - Information Science graduate with experience in international operations, customer success, and global sales.">
  <main id="main">
    <section class="hero">
      <img
        src="/profile.jpg"
        alt="Nikhil Parag"
        class="hero-image"
      />

      <h1>Nikhil Parag</h1>

      <p class="eyebrow">
        Founder of NPconscious
      </p>

      <p class="hero-description">
        Information Science graduate with experience in international operations, customer success, and global sales.
      </p>

      <div class="hero-actions">
        <a
          href="https://npconscious.com"
          target="_blank"
          class="btn btn-primary"
        >
          Explore NPconscious
        </a>

        <a
          href="#contact"
          class="btn btn-secondary"
        >
          Get In Touch
        </a>
      </div>
    </section>

    <section id="mission" class="section">
      <div class="content">
        <span class="section-label">
          MISSION
        </span>

        <h2>
          What Drives Me
        </h2>

        <p>
          Education should create independent thinkers, not dependent learners.
        </p>

        <p>
          Through technology, mentorship and practical problem solving, I aim to create learning experiences that remain valuable long after the classroom ends.
        </p>
      </div>
    </section>

    <section id="building" class="section">
      <div class="content">
        <span class="section-label">
          WHAT I'M BUILDING
        </span>

        <h2>
          NPconscious
        </h2>

        <p>
          NPconscious is focused on curiosity-driven learning, technology-enabled education and long-term personal growth.
        </p>

        <p>
          The goal is simple: help people become better thinkers, learners and decision makers.
        </p>
      </div>
    </section>

    <section class="stats">
      <div class="stat">
        <h3>1000+</h3>
        <p>
          Operational Cases Resolved
        </p>
      </div>

      <div class="stat">
        <h3>20+</h3>
        <p>
          People Coordinated
        </p>
      </div>

      <div class="stat">
        <h3>2</h3>
        <p>
          International Roles
        </p>
      </div>

      <div class="stat">
        <h3>1</h3>
        <p>
          Published Research Paper
        </p>
      </div>
    </section>

    <section id="work" class="section">
      <span class="section-label">
        MY WORK
      </span>

      <h2>
        completed projects
      </h2>

      <div class="project-grid">
        <article class="project featured">
          <span>
            Research
          </span>

          <h3>
            Signature Forgery Detection
          </h3>

          <p>
            Published machine learning research using One-shot Learning to identify forged signatures in the International Journal of Creative Research Thoughts (ISSN: 2320-2882).
          </p>
        </article>

        <article class="project">
          <span> DBMS </span>

          <h3>
            Blood Bank Management System
          </h3>
          <div class="project-tags">
            <span class="tag">PHP</span>
            <span class="tag">MySQL</span>
            <span class="tag">XAMPP</span>
          </div>

          <h3>
            Placement Management System
          </h3>
          <div class="project-tags">
            <span class="tag">Java Swing</span>
            <span class="tag">MySQL</span>
          </div>
        </article>

        <article class="project">
          <span> Tools </span>

          <h3>Car emi calculator</h3>
          <div class="project-tags">
            <span class="tag">Android Studio</span>
            <span class="tag">Java</span>
          </div>
        </article>
      </div>
    </section>

    <section class="section">
      <span class="section-label">
        What I'm Exploring
      </span>

      <h2>Areas of Focus</h2>

      <div class="expertise-grid">
        <article>
          <h3>
            Operations
          </h3>

          <p>
            Learning how to build and lead operations teams that can execute with excellence and adapt to change.
          </p>
        </article>

        <article>
          <h3>
            Sales
          </h3>

          <p>
            Learning sales strategies and techniques to drive revenue growth along with customer relationship management.
          </p>
        </article>

        <article>
          <h3>
            Technology
          </h3>

          <p>
            AI, software and product thinking.
          </p>
        </article>

        <article>
          <h3>
            Education
          </h3>

          <p>
            Next educational goal: MBA
          </p>
        </article>
      </div>
    </section>

    <section id="experience" class="section">
      <span class="section-label">
        CAREER JOURNEY
      </span>

      <h2>
        Experience
      </h2>

      <div class="timeline">
        <div class="timeline-item">
          <span>Present</span>

          <h3>
            Founder
          </h3>

          <p>
            NPconscious
          </p>
        </div>

        <div class="timeline-item">
          <span>2026</span>

          <h3>
            International Sales
          </h3>

          <p>
            Bhanzu
          </p>
        </div>

        <div class="timeline-item">
          <span>2025</span>

          <h3>
            International Operations
        </h3>

          <p>
            Concentrix (Airbnb)
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <span class="section-label">
        EDUCATION
      </span>

      <h2>
        Education & Credentials
      </h2>

      <div class="timeline">
        <div class="timeline-item">
          <h3>
            BE Information Science
          </h3>

          <p>
            Cambridge Institute of Technology
          </p>
        </div>

        <div class="timeline-item">
          <h3>
            Microsoft Azure Fundamentals
          </h3>
          <a 
            href="https://www.credly.com/badges/7ab00e03-af5a-4a03-99c9-7e264e02423e/public_url"
            target="_blank"
            rel="noopener noreferrer"
            class="credential-link"
          >
            View Credential →
          </a>
        </div>

        <div class="timeline-item">
          <h3>
            Microsoft Power Platform Fundamentals
          </h3>
          <a 
            href="https://www.credly.com/badges/861459a8-0b58-475a-8dbd-97450101926a/public_url"
            target="_blank"
            rel="noopener noreferrer"
            class="credential-link"
          >
            View Credential →
          </a>
        </div>
      </div>
    </section>

    <section id="contact" class="contact">
      <h2>
        Let's Build Something Meaningful
      </h2>

      <p>
        Open to collaborations, consulting opportunities and meaningful conversations.
      </p>

      <div class="hero-actions">
        <a
          href="https://wa.me/918088276492"
          class="btn btn-primary"
        >
          WhatsApp
        </a>

        <a
          href="mailto:nikhilparag0@gmail.com"
          class="btn btn-secondary"
        >
          Email
        </a>
      </div>
    </section>
  </main>
</Layout>
